# Yagura runtime config. Copy to .env (gitignored) and fill in.
#   cp .env.example .env
# Bind + DB are baked into the image (Dockerfile) — override only if needed.

# --- Alerts (optional; all unset = alerts log to stderr only) ---
YAGURA_TELEGRAM_TOKEN=
YAGURA_TELEGRAM_CHAT=
YAGURA_DISCORD_WEBHOOK=

# --- P4 route-drift ---
# Path INSIDE the container; the host file is bind-mounted read-only in compose.yaml.
YAGURA_CLOUDFLARED_CONFIG=/etc/cloudflared/config.yml

# --- P4 heartbeats --- comma-separated name=deadline_seconds
# e.g. hozon-backup=86400,deploy=3600   (jobs POST /beat/<name>; unknown names 404)
YAGURA_BEATS=

# --- P4 version-per-env --- comma-separated label=url
# e.g. kanjo-prod=http://127.0.0.1:8090/version,lazyscan-prod=http://127.0.0.1:8081/version
YAGURA_VERSION_URLS=
