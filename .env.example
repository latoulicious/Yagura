# --- Bind (REQUIRED for the host-mode deploy) ---
# compose.yaml uses network_mode: host so drift can TCP-probe the 127.0.0.1:<port>
# tunnel routes. The Dockerfile default 0.0.0.0:8080 collides with other services.
YAGURA_BIND=127.0.0.1:3001

# --- Alerts (optional; all unset = alerts log to stderr only) ---
YAGURA_TELEGRAM_TOKEN=
YAGURA_TELEGRAM_CHAT=
YAGURA_DISCORD_WEBHOOK=

# --- Route-drift ---
# Path INSIDE the container; the host file is bind-mounted read-only in compose.yaml.
YAGURA_CLOUDFLARED_CONFIG=/etc/cloudflared/config.yml

# --- Heartbeats --- comma-separated name=deadline_seconds
# e.g. hozon-backup=86400,deploy=3600   (jobs POST /beat/<name>; unknown names 404)
YAGURA_BEATS=

# --- Version-per-env --- comma-separated label=url
# e.g. kanjo-prod=http://127.0.0.1:9000/version,lazyscan-prod=http://127.0.0.1:8080/version
# host-mode: use 127.0.0.1:<published-port> — NOT container names (kanjo-api:3000);
# no Docker DNS in host mode, so a container hostname polls as ok:false.
YAGURA_VERSION_URLS=
